# Supabase (AI Agent Hub project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (GHL Token project - read-only)
GHL_TOKEN_SUPABASE_URL=
GHL_TOKEN_SUPABASE_SERVICE_KEY=

# GoHighLevel
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_API_BASE=https://services.leadconnectorhq.com

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude) — opcional, habilita modelos Claude no seletor
ANTHROPIC_API_KEY=

# Auth
JWT_SECRET=

# Cron
CRON_SECRET=

# Dev bypass (SOMENTE em ambientes de dev/teste — NUNCA em produção)
# Exige AMBAS as flags + NODE_ENV != production pra ativar a rota /api/auth/dev-login.
# NEXT_PUBLIC_DEV_MODE faz o botão aparecer na UI.
# DEV_MODE (server-only, não vaza pro bundle) autoriza o endpoint.
NEXT_PUBLIC_DEV_MODE=
DEV_MODE=

# Webhook — quando "true", rejeita qualquer inbound sem GHL_WEBHOOK_SECRET configurado.
# Use em produção pra bloquear spoofing de webhooks.
WEBHOOK_REQUIRE_SIGNATURE=
GHL_WEBHOOK_SECRET=

# Sentry — monitoramento de erros (OPCIONAL). Sem DSN o Sentry fica 100% inativo:
# o build e o runtime seguem idênticos. Pra ativar: crie um projeto Next.js em
# sentry.io (free tier) e cole o DSN abaixo no painel do Vercel.
NEXT_PUBLIC_SENTRY_DSN=
# Server-side (opcional): se não setar, server/edge caem pra NEXT_PUBLIC acima.
# Vantagem de setar: o DSN do server não vai pro bundle do browser.
SENTRY_DSN=
# Org/project slug + auth token: necessários SÓ pra subir source maps no build
# (stack traces legíveis). Opcionais — sem eles o Sentry ainda captura erros.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Amostragem de tracing (0 a 1). Default 0.1. Deixe baixo pra economizar quota.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Ponte Sentry → painel de Signals do hub (admin_signals). ON por padrão, mas só
# atua em produção (VERCEL_ENV=production). Defina "0" pra desligar de vez (crash
# deixa de virar signal, segue indo só pro Sentry).
SENTRY_SIGNALS_BRIDGE=

# Prospecção 2.0 (Pedro 2026-05-28): outreach runner do cron sparkbot-proactive.
# Default OFF — só roda quando admin ligar conscientemente após smoke. Quando "1",
# o cron varre agents lead-facing com outreach_config.enabled, respeita cooldown
# 24h por agente, e cria bulk_message_jobs em status='paused' (admin ativa via UI).
OUTREACH_RUNNER_ENABLED=
