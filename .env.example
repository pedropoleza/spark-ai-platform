# Supabase (AI Agent Hub project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (GHL Token project - read-only)
GHL_TOKEN_SUPABASE_URL=
GHL_TOKEN_SUPABASE_SERVICE_KEY=

# GoHighLevel
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_API_BASE=https://services.leadconnectorhq.com

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude) — opcional, habilita modelos Claude no seletor
ANTHROPIC_API_KEY=

# Auth
JWT_SECRET=

# Cron
CRON_SECRET=

# Dev bypass (SOMENTE em ambientes de dev/teste — NUNCA em produção)
# Exige AMBAS as flags + NODE_ENV != production pra ativar a rota /api/auth/dev-login.
# NEXT_PUBLIC_DEV_MODE faz o botão aparecer na UI.
# DEV_MODE (server-only, não vaza pro bundle) autoriza o endpoint.
NEXT_PUBLIC_DEV_MODE=
DEV_MODE=

# Webhook — quando "true", rejeita qualquer inbound sem GHL_WEBHOOK_SECRET configurado.
# Use em produção pra bloquear spoofing de webhooks.
WEBHOOK_REQUIRE_SIGNATURE=
GHL_WEBHOOK_SECRET=
